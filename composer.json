{
    "config": {
        "platform": {
            "php": "8.3"
        },
        "audit": {
            "ignore": [
                "PKSA-z3gr-8qht-p93v",
                "PKSA-y2cr-5h3j-g3ys",
                "PKSA-zh4j-by9m-7mz8",
                "PKSA-km2b-zc3b-mjm3"
            ]
        },
        "allow-plugins": {
            "simplesamlphp/composer-xmlprovider-installer": true,
            "simplesamlphp/composer-module-installer": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "8.0.0",
        "vittascience/vtuser": "1.3.6",
        "vittascience/vtinterfaces": "1.5.8",
        "vittascience/vtclassroom": "1.4.4",
        "vittascience/vtlearn": "1.4.6",
        "vittascience/vutils": "1.3.1",
        "symfony/var-dumper": "^6.4"
    },
    "require": {
        "doctrine/orm": "^2.6.2",
        "symfony/yaml": "^6.4",
        "mikey179/vfsstream": "^1.6.8",
        "monolog/monolog": "^2.0",
        "chriskonnertz/bbcode": "^1.1",
        "phpmailer/phpmailer": "^6.1",
        "aiken/i18next": "dev-master",
        "vlucas/phpdotenv": "^4.1",
        "google/apiclient": "^2.16",
        "firebase/php-jwt": "^6.0",
        "jasig/phpcas": "^1.3",
        "guzzlehttp/guzzle": "^7.5",
        "symfony/cache": "^6.4",
        "doctrine/annotations": "^1.13",
        "phpseclib/phpseclib": "^3.0",
        "php-opencloud/openstack": "^3.2",
        "league/oauth2-google": "^4.0",
        "simplesamlphp/simplesamlphp": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "Cmd\\": "cmd/",
            "DAO\\": "DAO/",
            "models\\": "models/",
            "Database\\": "database/src/",
            "VittaLogger\\": "vitta_logger/src/",
            "Interfaces\\": "vendor/vittascience/vtinterface/src",
            "User\\": "vendor/vittascience/vtuser/src",
            "Python\\": "python/",
            "Esp\\": "esp/",
            "Learn\\": "vendor/vittascience/vtlearn",
            "Utils\\": "vendor/vittascience/vutils/src",
            "Classroom\\": "vendor/vittascience/vtclassroom/src",
            "Plugins\\": "plugins"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EntityManager\\Tests\\": "entity_manager/tests",
            "EntityManager\\Tests\\Helpers\\": "entity_manager/tests/helpers"
        }
    }
}
